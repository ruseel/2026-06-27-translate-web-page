{:paths ["src" "viewer/src"]
 :tasks
 {:requires ([pipeline :as pipeline]
             [fetch :as fetch]
             [translate :as translate]
             [genhtml :as genhtml]
             [status :as status]
             [viewer.server :as viewer])

  page {:doc "Run fetch -> translate -> genhtml. Usage: bb page <url-or-defuddle-json> [ledger] (default ledger: translate)"
        :task (apply pipeline/-main *command-line-args*)}

  fetch {:doc "Fetch URL/Defuddle JSON, convert to JSON-LD, and insert into Fluree. Usage: bb fetch <url-or-defuddle-json> [ledger] (default ledger: translate)"
         :task (apply fetch/-main *command-line-args*)}

  translate {:doc "Query paragraphs from Fluree, call Pi, and insert translations with LLM metadata. Usage: bb translate <slug> OR bb translate <ledger> <slug>"
             :task (apply translate/-main *command-line-args*)}

  genhtml {:doc "Query paragraph pairs from Fluree and generate side-by-side HTML. Usage: bb genhtml <slug> OR bb genhtml <ledger> <slug>"
           :task (apply genhtml/-main *command-line-args*)}

  status {:doc "Inspect article, paragraph, translation, and latest-run state. Usage: bb status <slug> OR bb status <ledger> <slug>"
          :task (apply status/-main *command-line-args*)}

  viewer {:doc "Start the Fluree multiple-LLM translation viewer. Usage: bb viewer [port] (default 8123)"
          :task (apply viewer/-main *command-line-args*)}}}
